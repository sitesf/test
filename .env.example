# ==============================================================================
# Tufani — variabile de mediu
# Copiați acest fișier în `.env` și completați valorile reale.
# NICIO cheie nu este hardcodată în cod — totul vine din aceste variabile.
# ==============================================================================

# PostgreSQL connection string (local sau Render)
# Format: postgresql://USER:PAROLA@HOST:PORT/NUME_DB?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tufani?schema=public"

# Cheia secretă Stripe (test mode: începe cu sk_test_)
# O găsiți în Stripe Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY="completati-cheia-sk_test-din-dashboard"

# Secretul webhook-ului Stripe (începe cu whsec_)
# Local: afișat de `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# Producție: Stripe Dashboard -> Developers -> Webhooks -> Signing secret
STRIPE_WEBHOOK_SECRET="completati-secretul-whsec-al-webhookului"

# Secret pentru sesiunile NextAuth (generați cu: openssl rand -base64 32)
NEXTAUTH_SECRET="schimbati-cu-un-secret-aleatoriu-lung"

# URL-ul public al aplicației (folosit de NextAuth și pentru redirect-urile Stripe)
# Local: http://localhost:3000 | Producție: https://tufani.onrender.com
NEXTAUTH_URL="http://localhost:3000"

# Contul de administrator creat de scriptul de seed (prisma/seed.ts)
ADMIN_EMAIL="admin@tufani.ro"
ADMIN_PASSWORD="schimbati-aceasta-parola"
